{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "customer-api": {
        "ClusterId": "customer-api",
        "Match": {
          "Path": "/customers/{**catch-all}"
        }
      },
      "claims-api-root": {
        "ClusterId": "claims-api",
        "Match": {
          "Path": "/claims"
        }
      },
      "claims-api": {
        "ClusterId": "claims-api",
        "Match": {
          "Path": "/claims/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "customer-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5065/"
          }
        }
      },
      "claims-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5259/"
          }
        }
      }
    }
  }
}
