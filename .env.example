# Local Environment Variables (.env)
# Copy this file to .env and replace the values with your local development secrets.
# DO NOT COMMIT the actual .env file.

# SQL Server
# Must meet SQL Server password complexity requirements.
SQL_PASSWORD=<set-local-sql-password-here>

# JWT Configuration
# Ensure the key is at least 32 characters long.
JWT_KEY=<set-local-jwt-key-here>
JWT_ISSUER=EnterpriseClaimsLocal
JWT_AUDIENCE=EnterpriseClaimsApi
